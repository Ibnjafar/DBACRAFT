# Series : Centralized DB Authentication in the Wild
# Part   : 2 - Building an Enterprise LDAP Directory with OpenLDAP
# File   : 04-users-dev.ldif
# Purpose: Create developer accounts under ou=people
# Load   : ldapadd -x -D "cn=admin,dc=dbacraft,dc=com" -W -f 04-users-dev.ldif

dn: uid=user_arif_dev,ou=people,dc=dbacraft,dc=com
objectClass: inetOrgPerson
uid: user_arif_dev
cn: Arif
sn: Dev
mail: arif@dbacraft.com
userPassword: CHANGE_ME

